{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "description": "Renovate configuration for choco-podman-cli",
  "labels": ["dependencies"],
  "semanticCommits": "enabled",
  "commitMessageTopic": "{{depName}}",
  "commitMessageExtra": "to {{newVersion}}",
  "customManagers": [
    {
      "description": "Track Podman release version in the Chocolatey install script",
      "customType": "regex",
      "managerFilePatterns": ["/^tools/chocolateyInstall\\.ps1$/"],
      "matchStrings": [
        "https://github\\.com/containers/podman/releases/download/v(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)/"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "containers/podman",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "description": "Podman core release",
      "matchDepNames": ["containers/podman"],
      "labels": ["podman-update"]
    }
  ]
}
